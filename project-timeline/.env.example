# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── PostgreSQL (used by docker-compose.yml and server/) ──────────────────────
POSTGRES_DB=project_timeline
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Full URL for the server (auto-constructed in docker-compose.yml,
# but needed if running the server outside Docker):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_timeline

# ── Express server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Client port (what port is exposed on your host machine) ──────────────────
CLIENT_PORT=80

# ── CORS (only needed when server runs outside Docker) ───────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ── Auth (add when implementing login) ───────────────────────────────────────
# SESSION_SECRET=replace_with_a_long_random_string
